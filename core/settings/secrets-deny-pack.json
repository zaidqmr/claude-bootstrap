{
  "_comment": "Mandatory layered .env / secrets protection. Anthropic-confirmed leak: Claude reads .env via Bash(cat) even when .gitignore'd. Layered deny (Read + Bash variants) is the only reliable mitigation. Merge into your settings.json permissions.deny array.",
  "_source": "https://eve.gd/2026/04/19/claude-code-can-consume-transmit-env-files",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.development)",
      "Read(./.env.staging)",
      "Read(./.env.test)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(./id_rsa)",
      "Read(./id_rsa.pub)",
      "Read(./id_ed25519)",
      "Read(./id_ed25519.pub)",
      "Read(./credentials.json)",
      "Read(./credentials/*)",
      "Read(./secrets.json)",
      "Read(./secrets/*)",
      "Read(./.aws/credentials)",
      "Read(./.ssh/*)",
      "Read(./.gnupg/*)",

      "Bash(cat:./.env)",
      "Bash(cat:./.env.*)",
      "Bash(grep:./.env*)",
      "Bash(head:./.env*)",
      "Bash(tail:./.env*)",
      "Bash(less:./.env*)",
      "Bash(more:./.env*)",
      "Bash(awk:./.env*)",
      "Bash(sed:./.env*)",
      "Bash(xxd:./.env*)",
      "Bash(od:./.env*)",

      "Bash(cat:./id_rsa*)",
      "Bash(cat:./id_ed25519*)",
      "Bash(cat:./*.pem)",
      "Bash(cat:./*.key)",
      "Bash(cat:./credentials*)",
      "Bash(cat:./secrets*)",
      "Bash(cat:./.aws/*)",
      "Bash(cat:./.ssh/*)",
      "Bash(cat:./.gnupg/*)"
    ]
  }
}
